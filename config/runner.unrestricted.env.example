# 如果要在隔离的 Ubuntu 沙箱服务器上让 Codex 最大程度自主运行，
# 可以把本文件复制为 config/runner.env。

export CODEX_BIN=codex

# 可选：
# export CODEX_MODEL=gpt-5-codex
# export CODEX_PROFILE=default

# 0 表示一直运行。
export CODEX_MAX_ROUNDS=0
export CODEX_SLEEP_SECONDS=10
export CODEX_MAX_CONSECUTIVE_FAILURES=5

# codex exec 被外部执行器 SIGTERM 时常见退出码是 143。
# 在隔离服务器长期自迭代时，默认不因这类中断停止，而是继续 resume。
export CODEX_RECOVERABLE_EXIT_CODES=143
export CODEX_MAX_RECOVERABLE_INTERRUPTS=0

# 默认情况下，runner 会保存 codex exec 的 session id，并在下一轮显式 resume。
# 如果需要丢弃旧会话记忆、重新建立 Codex 会话，可设为 1。
export CODEX_RESET_SESSION=0

# 默认使用进取式自主迭代。
# 隔离服务器上建议保持开启，让 Codex 在完成初始需求后继续：
# - 全面验证项目
# - 主动提出新功能候选
# - 写新功能文档并继续开发
export CODEX_STRATEGY_MODE=expansive
export CODEX_BASELINE_VERIFY=1
export CODEX_FEATURE_DISCOVERY=1

# 运行控制文件默认创建在 runs/<project>/control 下。
# 执行 touch runs/<project>/control/stop-after-current-round 后，
# runner 会在当前 Codex 轮次结束后停止。
# 每轮固定注入的长期上下文。默认读取 docs/context/*.md 和 docs/context/*.txt。
# export CODEX_CONTEXT_DOCS_DIR=/custom/path/context
# export CODEX_CONTEXT_FILES=/srv/shared/product-principles.md:/srv/shared/test-fixtures.md

# 可以用下面两种方式为下一轮追加一次性需求：
# - runs/<project>/control/next-requirements.md
# - runs/<project>/requests/*.md
export CODEX_CONSUME_REQUIREMENTS=1

# 隔离服务器最大权限模式。
# 这会启用：
# - --dangerously-bypass-approvals-and-sandbox
# - 顶层 --search
# - 在提示词中授权 sudo、安装依赖、写脚本、启动服务和监控状态
export CODEX_UNRESTRICTED=1

# 当 CODEX_UNRESTRICTED=1 时，下面这些配置是冗余的。
# 这里保留显式配置，便于阅读和按需调整。
export CODEX_DANGER_FULL_ACCESS=1
export CODEX_ENABLE_SEARCH=1
export CODEX_ALLOW_SUDO=1
export CODEX_ALLOW_INSTALL=1
export CODEX_ALLOW_LONG_RUNNING=1
export CODEX_ALLOW_SCRIPTING=1

# 仅在 CODEX_DANGER_FULL_ACCESS=0 且 CODEX_FULL_AUTO=0 时使用。
export CODEX_RUNNER_SANDBOX=danger-full-access
export CODEX_FULL_AUTO=0

# 可选，原样追加到 `codex exec` 的额外参数。
# export CODEX_EXTRA_ARGS='--some-flag'
