# 复制为 config/runner.env，然后在服务器上按需修改。

export CODEX_BIN=codex

# 可选：
# export CODEX_MODEL=gpt-5-codex
# export CODEX_PROFILE=default

# 0 表示一直运行。
export CODEX_MAX_ROUNDS=0
export CODEX_SLEEP_SECONDS=10
export CODEX_MAX_CONSECUTIVE_FAILURES=3

# 默认使用进取式自主迭代：
# - 当前需求完成后主动做全面验证
# - 主动发现和规划新功能
# - 为新功能创建新的迭代文档并继续开发
# 如果只想做保守维护，可把 CODEX_STRATEGY_MODE 改为 conservative。
export CODEX_STRATEGY_MODE=expansive
export CODEX_BASELINE_VERIFY=1
export CODEX_FEATURE_DISCOVERY=1

# 运行控制文件默认创建在 runs/<project>/control 下。
# 执行 touch runs/<project>/control/stop-after-current-round 后，
# runner 会在当前 Codex 轮次结束后停止。
# export CODEX_STOP_AFTER_CURRENT_ROUND_FILE=/custom/path/stop-after-current-round

# 每轮固定注入的长期上下文。默认读取 docs/context/*.md 和 docs/context/*.txt。
# 适合放产品方向、长期规则、测试素材路径、风格标准等不会随单轮完成而消失的信息。
# export CODEX_CONTEXT_DOCS_DIR=/custom/path/context
# export CODEX_CONTEXT_FILES=/srv/shared/product-principles.md:/srv/shared/test-fixtures.md

# 可以用下面两种方式为下一轮追加一次性需求：
# - runs/<project>/control/next-requirements.md
# - runs/<project>/requests/*.md
# 默认情况下，一轮成功结束后，已注入的需求文件会移动到 requests/processed。
export CODEX_CONSUME_REQUIREMENTS=1
# export CODEX_NEXT_REQUIREMENTS_FILE=/custom/path/next-requirements.md
# export CODEX_REQUESTS_DIR=/custom/path/requests

# read-only | workspace-write | danger-full-access
export CODEX_RUNNER_SANDBOX=workspace-write

# 只应在外部隔离的 VM/container 中启用。
export CODEX_DANGER_FULL_ACCESS=0

# 使用 Codex 的低阻力自动模式，而不是显式 sandbox 配置。
export CODEX_FULL_AUTO=0

# 如果当前 Codex 安装和账号支持，可以启用实时网页搜索。
export CODEX_ENABLE_SEARCH=0

# 可选，原样追加到 `codex exec` 的额外参数。
# export CODEX_EXTRA_ARGS='--some-flag'
